---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import changelog from '../data/changelog.json';
import { Plus, RefreshCw, Trash2, AlertTriangle, Wrench } from 'lucide-astro';

const typeConfig: Record<string, { label: string; color: string; bg: string }> = {
  added:      { label: 'Added',      color: 'text-emerald-400', bg: 'bg-emerald-400/10' },
  changed:    { label: 'Changed',    color: 'text-blue-400',    bg: 'bg-blue-400/10' },
  deprecated: { label: 'Deprecated', color: 'text-amber-400',   bg: 'bg-amber-400/10' },
  removed:    { label: 'Removed',    color: 'text-red-400',     bg: 'bg-red-400/10' },
  fixed:      { label: 'Fixed',      color: 'text-cyan-400',    bg: 'bg-cyan-400/10' },
};
---

<Layout title="Changelog — Argon Bot API">
  <Navbar current="/changelog/" />

  <main id="main-content" class="pt-14 min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-10">
      <div class="animate-fade-in-up mb-10">
        <h1 class="text-3xl font-bold tracking-tight mb-2">Changelog</h1>
        <p class="text-text-secondary">All notable changes to the Argon Bot API.</p>
      </div>

      <div class="space-y-12 animate-fade-in-up-delay-1">
        {changelog.map((release: any) => (
          <section class="relative">
            {/* Version header */}
            <div class="flex items-center gap-3 mb-4">
              <h2 class="text-xl font-bold">{release.version}</h2>
              <span class="text-xs text-text-muted font-mono">{release.date}</span>
            </div>

            {release.title && (
              <p class="text-sm text-text-secondary mb-4">{release.title}</p>
            )}

            {/* Changes grouped by type */}
            <div class="space-y-2">
              {release.changes.map((change: any) => {
                const cfg = typeConfig[change.type] || typeConfig.changed;
                return (
                  <div class="flex items-start gap-3 py-2">
                    <span class:list={["text-[10px] px-2 py-0.5 rounded-full font-semibold shrink-0 mt-0.5", cfg.color, cfg.bg]}>
                      {cfg.label}
                    </span>
                    <div class="flex-1">
                      {change.interface && (
                        <a href={`/docs/${change.interface}/`} class="text-sm font-mono text-accent hover:text-accent-hover transition-colors mr-2">
                          {change.interface}
                        </a>
                      )}
                      <span class="text-sm text-text-secondary">{change.description}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
