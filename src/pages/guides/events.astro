---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { Radio, Zap, AlertTriangle, RefreshCw, Database } from 'lucide-astro';
import fullManifest from '../../data/api-manifest.json';

const intents = fullManifest.intents;
const events = fullManifest.events;

// Group events by category for the table
const categories = [...new Set(events.map((e: any) => e.category))];

// Compute common intent combinations
const allNonPriv = intents.filter((i: any) => !i.isPrivileged).reduce((sum: number, i: any) => sum | i.value, 0);
const allIntents = intents.reduce((sum: number, i: any) => sum | i.value, 0);

// --- Type shape rendering (reused from [interface].astro) ---
interface TypeProperty {
  name: string;
  type: string;
  isArray: boolean;
  isNullable: boolean;
  isCircular: boolean;
  properties?: TypeProperty[] | null;
  enumValues?: string[] | null;
  isUnion?: boolean;
  discriminatorField?: string | null;
  discriminatorType?: string | null;
  variants?: UnionVariant[] | null;
}

interface UnionVariant {
  name: string;
  discriminatorValue: string | null;
  properties: TypeProperty[];
}

interface TypeField {
  name: string;
  type: string;
  isArray: boolean;
  isNullable: boolean;
  isCircular: boolean;
  enumValues?: string[] | null;
  depth: number;
  isNested: boolean;
}

function flattenProperties(props: TypeProperty[] | null | undefined, depth = 0): TypeField[] {
  if (!props) return [];
  const result: TypeField[] = [];
  for (const prop of props) {
    // Skip expanding union variants inline — those are rendered separately
    if (prop.isUnion) {
      result.push({
        name: prop.name,
        type: prop.type,
        isArray: prop.isArray,
        isNullable: prop.isNullable,
        isCircular: prop.isCircular,
        enumValues: prop.enumValues,
        depth,
        isNested: depth > 0,
      });
      continue;
    }
    result.push({
      name: prop.name,
      type: prop.type,
      isArray: prop.isArray,
      isNullable: prop.isNullable,
      isCircular: prop.isCircular,
      enumValues: prop.enumValues,
      depth,
      isNested: depth > 0,
    });
    if (prop.properties) {
      result.push(...flattenProperties(prop.properties, depth + 1));
    }
  }
  return result;
}

function formatType(field: TypeField): string {
  let t = field.type;
  if (field.enumValues?.length) {
    t = field.enumValues
      .map(v => `<span class="type-enum">&quot;${v}&quot;</span>`)
      .join(' <span class="type-punct">|</span> ');
  } else {
    const allPrimitives = /\b(string|boolean|any|int32|uint32|int64|uint64|int16|uint8|float|double|decimal)\b/g;
    t = t.replace(allPrimitives, (m: string) => `<span class="type-keyword">${m}</span>`);
    t = t.replace(/\b([A-Z]\w+)/g, '<span class="type-name">$1</span>');
  }
  if (field.isArray) t += '<span class="type-punct">[]</span>';
  if (field.isNullable) t += ' <span class="type-punct">|</span> <span class="type-keyword">null</span>';
  if (field.isCircular) t += ' <span class="text-text-faint">(circular)</span>';
  return t;
}

function toCamelCase(s: string): string {
  return s[0].toLowerCase() + s.slice(1);
}
---

<DocsLayout title="Real-time Events (SSE) — Argon Bot API" current="/guides/events/" toc={[
  { id: "connecting", title: "Connecting" },
  { id: "intents", title: "Intents" },
  { id: "event-format", title: "Event Format" },
  { id: "lifecycle", title: "Connection Lifecycle" },
  { id: "reconnection", title: "Reconnection & Replay" },
  { id: "code-examples", title: "Code Examples" },
  { id: "all-events", title: "All Event Types" },
]}>
  <div class="animate-fade-in-up">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Real-time Events</h1>
    <p class="text-text-secondary text-lg">Subscribe to live events via Server-Sent Events (SSE) — messages, member activity, voice state, and more.</p>
  </div>

  <div class="mt-10 space-y-12 animate-fade-in-up-delay-1">

    <!-- Connecting -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Radio class="size-5 text-accent" />
        <h2 id="connecting" class="text-xl font-semibold">Connecting to the Event Stream <a href="#connecting" class="anchor-link">#</a></h2>
      </div>

      <div class="space-y-4">
        <p class="text-text-secondary">
          Open a persistent HTTP connection to the SSE endpoint. Events will be pushed to you in real time:
        </p>

        <div class="code-block text-[12px]">
          <pre set:html={`<span class="type-property">GET</span> /api/bot/IEvents/v1/Stream?intents=<span class="text-accent">{bitmask}</span>

<span class="text-text-muted">Headers:</span>
  Authorization: Bot YOUR_TOKEN
  Accept: text/event-stream`} />
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-oled-border-subtle">
                <th class="text-left py-2 px-3 text-text-muted font-medium">Parameter</th>
                <th class="text-left py-2 px-3 text-text-muted font-medium">Type</th>
                <th class="text-left py-2 px-3 text-text-muted font-medium">Description</th>
              </tr>
            </thead>
            <tbody class="text-text-secondary">
              <tr class="border-b border-oled-border-subtle">
                <td class="py-2 px-3 font-mono">intents</td>
                <td class="py-2 px-3 font-mono text-accent-2">number</td>
                <td class="py-2 px-3">Bitmask of event categories to receive. Defaults to all non-privileged intents if omitted.</td>
              </tr>
              <tr>
                <td class="py-2 px-3 font-mono">lastEventId</td>
                <td class="py-2 px-3 font-mono text-accent-2">string</td>
                <td class="py-2 px-3">Resume from a previous event ID. Can also be sent as the <code class="bg-oled-elevated px-1 rounded text-[11px]">Last-Event-ID</code> header.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Intents -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Zap class="size-5 text-accent" />
        <h2 id="intents" class="text-xl font-semibold">Intents <a href="#intents" class="anchor-link">#</a></h2>
      </div>

      <div class="space-y-4">
        <p class="text-text-secondary">
          Intents are a bitmask that controls which events you receive. Combine flags with bitwise OR.
          For example, <code class="bg-oled-elevated px-1.5 py-0.5 rounded font-mono text-[11px]">intents=5</code> subscribes to Messages (1) + Channels (4).
        </p>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-oled-border-subtle">
                <th class="text-left py-2 px-3 text-text-muted font-medium">Intent</th>
                <th class="text-left py-2 px-3 text-text-muted font-medium">Bit</th>
                <th class="text-left py-2 px-3 text-text-muted font-medium">Value</th>
                <th class="text-left py-2 px-3 text-text-muted font-medium">Events</th>
              </tr>
            </thead>
            <tbody class="text-text-secondary">
              {intents.map((intent: any, idx: number) => (
                <tr class:list={[
                  idx < intents.length - 1 && "border-b border-oled-border-subtle",
                  intent.isPrivileged && "bg-status-degraded-subtle/30"
                ]}>
                  <td class="py-2 px-3 font-mono">
                    {intent.name}
                    {intent.isPrivileged && <span class="text-[10px] text-status-degraded ml-1">(privileged)</span>}
                  </td>
                  <td class="py-2 px-3 font-mono">{intent.bit}</td>
                  <td class="py-2 px-3 font-mono text-accent">{intent.value}</td>
                  <td class="py-2 px-3">{intent.events.join(', ') || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="flex items-start gap-3 rounded-xl border border-status-degraded/20 bg-status-degraded-subtle p-4">
          <AlertTriangle class="size-4 text-status-degraded mt-0.5 shrink-0" />
          <p class="text-sm text-text-secondary">
            <strong class="text-text-primary">Privileged intents</strong> (Members, Presence) require your bot to be verified. Requesting privileged intents without verification will result in an error.
          </p>
        </div>

        <div class="code-block text-[12px]">
          <div class="text-text-muted mb-2 text-[11px]">Common combinations</div>
          <pre set:html={`<span class="text-text-muted">// Messages + Commands + Voice</span>
intents = 1 | 64 | 2048 = <span class="text-accent">2113</span>

<span class="text-text-muted">// All non-privileged (default)</span>
intents = <span class="text-accent">${allNonPriv}</span>

<span class="text-text-muted">// Everything (requires verification)</span>
intents = <span class="text-accent">${allIntents}</span>`} />
        </div>
      </div>
    </section>

    <!-- Event Format -->
    <section>
      <h2 id="event-format" class="text-xl font-semibold mb-4">Event Format <a href="#event-format" class="anchor-link">#</a></h2>

      <div class="space-y-4">
        <p class="text-text-secondary">
          Events follow the standard <a href="https://developer.mozilla.org/en-US/docs/Web/API/Server-sent_events" target="_blank" rel="noopener" class="text-accent hover:underline">SSE specification</a>.
          Each event has <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">id</code>, <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">event</code>, and <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">data</code> fields:
        </p>

        <div class="code-block text-[12px]">
          <pre set:html={`id: 42
event: messageCreate
data: {"messageId":12345,"text":"Hello!","creatorId":"...","channelId":"...","spaceId":"..."}`} />
        </div>

        <p class="text-text-secondary">The <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">data</code> field is the event payload — serialized directly as JSON (no wrapper object). The SSE <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">event</code> field is the event type in camelCase:</p>

        <div class="code-block text-[12px]">
          <pre set:html={`id: abc123def456_42
event: messageCreate
data: {"messageId":12345,"text":"Hello!","spaceId":"...","channelId":"...","creatorId":"..."}`} />
        </div>
      </div>
    </section>

    <!-- Connection Lifecycle -->
    <section>
      <h2 id="lifecycle" class="text-xl font-semibold mb-4">Connection Lifecycle <a href="#lifecycle" class="anchor-link">#</a></h2>

      <div class="space-y-4">
        <p class="text-text-secondary">When you connect, the server sends events in this order:</p>

        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-subtle text-[11px] font-bold text-accent mt-0.5">1</span>
            <div>
              <p class="text-sm font-medium">Ready + Bot goes Online</p>
              <p class="text-sm text-text-secondary">Sent immediately. Contains your active intents and the list of space IDs the bot belongs to. The bot's status is set to <strong class="text-text-primary">Online</strong> in all its spaces upon connection.</p>
              <div class="code-block text-[11px] mt-2">
                <pre set:html={`id: ready
event: ready
data: {"intents":4045,"spaceIds":["uuid-1","uuid-2"]}`} />
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-subtle text-[11px] font-bold text-accent mt-0.5">2</span>
            <div>
              <p class="text-sm font-medium">Live Events</p>
              <p class="text-sm text-text-secondary">Events matching your intents are pushed as they occur.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-subtle text-[11px] font-bold text-accent mt-0.5">3</span>
            <div>
              <p class="text-sm font-medium">Heartbeat</p>
              <p class="text-sm text-text-secondary">
                A <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">heartbeat</code> event is sent every <strong class="text-text-primary">30 seconds</strong> of inactivity to keep the connection alive.
                The heartbeat resets after each batch of events, so you'll only see it during idle periods.
              </p>
              <p class="text-sm text-text-secondary mt-2">
                The heartbeat <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">id</code> is a <strong class="text-text-primary">cursor</strong> encoding the bot's position in each space's event stream.
                The <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">timestamp</code> is milliseconds since the <strong class="text-text-primary">Argon Epoch</strong> (January 1, 2025 00:00:00 UTC).
              </p>
              <div class="code-block text-[11px] mt-2">
                <pre set:html={`id: a1b2c3d4....:42,e5f6a7b8....:17
event: heartbeat
data: {"timestamp":40953660000}`} />
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-status-degraded-subtle text-[11px] font-bold text-status-degraded mt-0.5">✕</span>
            <div>
              <p class="text-sm font-medium">Disconnect → Bot goes Offline</p>
              <p class="text-sm text-text-secondary">When the SSE connection closes (client disconnect, network drop, etc.), the bot's status is set to <strong class="text-text-primary">Offline</strong> in all its spaces. Reconnecting will automatically resume from where you left off.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Reconnection -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <RefreshCw class="size-5 text-accent" />
        <h2 id="reconnection" class="text-xl font-semibold">Reconnection &amp; Replay <a href="#reconnection" class="anchor-link">#</a></h2>
      </div>

      <div class="space-y-4">
        <p class="text-text-secondary">
          If your connection drops, you can resume without missing events. The server tracks your position in each space's event stream automatically.
        </p>

        <p class="text-text-secondary">
          Simply reconnect to the same endpoint. Events will be delivered from where you left off. Your stream position is kept for <strong class="text-text-primary">10 minutes</strong> after disconnect — if you reconnect within that window, no events are lost.
        </p>

        <div class="code-block text-[12px]">
          <pre set:html={`<span class="text-text-muted">Option 1: Query parameter</span>
GET /api/bot/IEvents/v1/Stream?intents=4045&lastEventId=<span class="text-accent">42</span>

<span class="text-text-muted">Option 2: Standard SSE header</span>
Last-Event-ID: <span class="text-accent">42</span>`} />
        </div>

        <p class="text-text-secondary">
          The server will replay missed events, then send a <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">Resumed</code> event with the count of replayed events before switching to live:
        </p>

        <div class="code-block text-[11px]">
          <pre set:html={`<span class="text-text-muted">// Replayed events arrive first...</span>
{ "id": "43", "type": "...", "data": { ... } }
{ "id": "44", "type": "...", "data": { ... } }

<span class="text-text-muted">// Then the Resumed marker</span>
{ "id": "resumed", "type": "Resumed", "data": { "replayedCount": 2 } }

<span class="text-text-muted">// Then live events continue</span>`} />
        </div>
      </div>
    </section>

    <!-- Code Examples -->
    <section>
      <h2 id="code-examples" class="text-xl font-semibold mb-4">Code Examples <a href="#code-examples" class="anchor-link">#</a></h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-3">TypeScript (Bun / Node.js)</h3>
          <div class="code-block text-[12px]">
            <pre set:html={`<span class="text-accent-3">import</span> EventSource <span class="text-accent-3">from</span> <span class="text-accent-2">"eventsource"</span>;

<span class="text-accent-3">const</span> es = <span class="text-accent-3">new</span> <span class="type-name">EventSource</span>(
  <span class="text-accent-2">"https://api.argon.gl/api/bot/IEvents/v1/Stream?intents=2113"</span>,
  { headers: { <span class="text-accent-2">"Authorization"</span>: <span class="text-accent-2">"Bot YOUR_TOKEN"</span> } }
);

es.<span class="type-property">addEventListener</span>(<span class="text-accent-2">"ready"</span>, (e) => {
  <span class="text-accent-3">const</span> data = <span class="type-name">JSON</span>.parse(e.data);
  console.log(<span class="text-accent-2">"Connected, spaces:"</span>, data.spaceIds);
});

es.<span class="type-property">addEventListener</span>(<span class="text-accent-2">"messageCreate"</span>, (e) => {
  <span class="text-accent-3">const</span> data = <span class="type-name">JSON</span>.parse(e.data);
  console.log(<span class="text-accent-2">\`[\${data.channelId}] \${data.text}\`</span>);
});

es.<span class="type-property">addEventListener</span>(<span class="text-accent-2">"heartbeat"</span>, () => {
  <span class="text-text-muted">// Connection is alive</span>
});

es.<span class="type-property">onerror</span> = () => {
  <span class="text-text-muted">// EventSource auto-reconnects with Last-Event-ID</span>
};`} />
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-3">C# (.NET)</h3>
          <div class="code-block text-[12px]">
            <pre set:html={`<span class="text-accent-3">using var</span> client = <span class="text-accent-3">new</span> <span class="type-name">HttpClient</span>();
client.DefaultRequestHeaders.Add(<span class="text-accent-2">"Authorization"</span>, <span class="text-accent-2">"Bot YOUR_TOKEN"</span>);

<span class="text-accent-3">using var</span> stream = <span class="text-accent-3">await</span> client.GetStreamAsync(
    <span class="text-accent-2">"https://api.argon.gl/api/bot/IEvents/v1/Stream?intents=2113"</span>);
<span class="text-accent-3">using var</span> reader = <span class="text-accent-3">new</span> <span class="type-name">StreamReader</span>(stream);

<span class="type-name">string</span>? eventType = <span class="text-accent-3">null</span>;
<span class="text-accent-3">while</span> (<span class="text-accent-3">await</span> reader.ReadLineAsync() <span class="text-accent-3">is</span> { } line)
{
    <span class="text-accent-3">if</span> (line.StartsWith(<span class="text-accent-2">"event: "</span>))
        eventType = line[<span class="text-accent-2">7</span>..];  <span class="text-text-muted">// e.g. "messageCreate", "heartbeat"</span>
    <span class="text-accent-3">else if</span> (line.StartsWith(<span class="text-accent-2">"data: "</span>))
    {
        <span class="text-accent-3">var</span> payload = <span class="type-name">JsonDocument</span>.Parse(line[<span class="text-accent-2">6</span>..]);
        <span class="type-name">Console</span>.WriteLine(<span class="text-accent-2">$"[{eventType}] {payload.RootElement}"</span>);
    }
}`} />
          </div>
        </div>
      </div>
    </section>

    <!-- All Event Types -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Database class="size-5 text-accent" />
        <h2 id="all-events" class="text-xl font-semibold">All Event Types <a href="#all-events" class="anchor-link">#</a></h2>
      </div>

      <p class="text-text-secondary mb-6">
        Each event is delivered as an SSE <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">event:</code> with the type name in camelCase.
        The <code class="bg-oled-elevated px-1 rounded font-mono text-[11px]">data:</code> field contains the JSON payload described below.
      </p>

      <!-- Quick nav by category -->
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map((cat: string) => (
          <a href={`#cat-${cat.toLowerCase()}`} class="text-xs px-3 py-1.5 rounded-lg bg-oled-surface border border-oled-border-subtle text-text-secondary hover:text-accent hover:border-accent/30 transition-colors">
            {cat}
          </a>
        ))}
      </div>

      {categories.map((cat: string) => {
        const catEvents = events.filter((e: any) => e.category === cat);
        return (
          <div class="mb-10" id={`cat-${cat.toLowerCase()}`}>
            <h3 class="text-lg font-semibold mb-4 text-text-muted">{cat}</h3>
            <div class="space-y-6">
              {catEvents.map((evt: any) => {
                const eventAnchor = toCamelCase(evt.name);
                const hasPayload = evt.payloadTypeShape || evt.payloadVariants;
                const flatFields = flattenProperties(evt.payloadTypeShape);
                const unionFields = (evt.payloadTypeShape || []).filter((p: any) => p.isUnion);

                return (
                  <section class="glass rounded-2xl overflow-hidden" id={eventAnchor}>
                    {/* Event header */}
                    <div class="flex items-center gap-3 px-5 py-3 border-b border-oled-border-subtle">
                      <code class="text-sm font-mono font-bold text-accent">{eventAnchor}</code>
                      {evt.intent && (
                        <span class="text-[10px] px-2 py-0.5 rounded-full font-medium bg-accent-subtle text-accent border border-accent/20">
                          {evt.intent}
                        </span>
                      )}
                      {evt.isStable && (
                        <span class="text-[10px] px-2 py-0.5 rounded-full font-medium bg-status-healthy-subtle text-status-healthy border border-status-healthy/20">
                          STABLE
                        </span>
                      )}
                      {evt.payloadTypeName && (
                        <span class="ml-auto text-[10px] font-mono text-text-faint">{evt.payloadTypeName}</span>
                      )}
                    </div>

                    <div class="p-5 space-y-4">
                      {/* Description */}
                      {evt.description && (
                        <p class="text-sm text-text-secondary">{evt.description}</p>
                      )}

                      {/* Single payload type shape */}
                      {evt.payloadTypeShape && flatFields.length > 0 && (
                        <div>
                          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">
                            Payload
                          </h4>
                          <div class="type-grid">
                            <div class="type-grid-header">
                              <span>Field</span>
                              <span>Type</span>
                            </div>
                            {flatFields.map((field: TypeField) => (
                              <div class:list={["type-grid-row", field.isNested && "type-grid-nested"]} style={field.depth > 0 ? `padding-left: ${field.depth * 20 + 12}px` : undefined}>
                                <span class="type-property font-mono text-[12px]">
                                  {field.depth > 0 && <span class="text-text-faint mr-1">↳</span>}
                                  {field.name}
                                </span>
                                <span class="font-mono text-[12px]" set:html={formatType(field)} />
                              </div>
                            ))}
                          </div>
                        </div>
                      )}

                      {/* Union type variants (e.g. IMessageEntity inside payload) */}
                      {unionFields.map((uf: any) => uf.variants?.length > 0 && (
                        <div>
                          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">
                            {uf.name} variants
                            {uf.discriminatorField && (
                              <span class="text-[10px] font-mono font-normal text-text-faint ml-2">
                                discriminator: {uf.discriminatorField}
                                {uf.discriminatorType && ` (${uf.discriminatorType})`}
                              </span>
                            )}
                          </h4>
                          {uf.type === 'IMessageEntity' && (
                            <p class="text-sm text-text-secondary mb-3">
                              See the <a href="/guides/message-entities/" class="text-accent hover:underline">Message Entities guide</a> for detailed documentation on all entity types, formatting rules, and examples.
                            </p>
                          )}
                          <div class="space-y-3">
                            {uf.variants.map((variant: UnionVariant) => {
                              const variantFields = flattenProperties(variant.properties);
                              return variantFields.length > 0 && (
                                <details class="group">
                                  <summary class="cursor-pointer text-sm font-mono text-text-secondary hover:text-accent transition-colors py-1">
                                    <span class="ml-1">{variant.name}</span>
                                    {variant.discriminatorValue && (
                                      <span class="text-[10px] text-text-faint ml-2">= "{variant.discriminatorValue}"</span>
                                    )}
                                  </summary>
                                  <div class="type-grid mt-2 ml-4">
                                    <div class="type-grid-header">
                                      <span>Field</span>
                                      <span>Type</span>
                                    </div>
                                    {variantFields.map((field: TypeField) => (
                                      <div class:list={["type-grid-row", field.isNested && "type-grid-nested"]} style={field.depth > 0 ? `padding-left: ${field.depth * 20 + 12}px` : undefined}>
                                        <span class="type-property font-mono text-[12px]">
                                          {field.depth > 0 && <span class="text-text-faint mr-1">↳</span>}
                                          {field.name}
                                        </span>
                                        <span class="font-mono text-[12px]" set:html={formatType(field)} />
                                      </div>
                                    ))}
                                  </div>
                                </details>
                              );
                            })}
                          </div>
                        </div>
                      ))}

                      {/* N:1 payload variants (multiple source types for one event) */}
                      {evt.payloadVariants && (
                        <div>
                          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">
                            Payload Variants
                            <span class="text-[10px] font-normal text-text-faint ml-2">
                              This event can carry different payload shapes depending on the source
                            </span>
                          </h4>
                          <div class="space-y-4">
                            {evt.payloadVariants.map((pv: any) => {
                              const pvFields = flattenProperties(pv.shape);
                              return (
                                <div>
                                  <h5 class="text-sm font-mono text-text-secondary mb-2">{pv.typeName}</h5>
                                  {pvFields.length > 0 && (
                                    <div class="type-grid">
                                      <div class="type-grid-header">
                                        <span>Field</span>
                                        <span>Type</span>
                                      </div>
                                      {pvFields.map((field: TypeField) => (
                                        <div class:list={["type-grid-row", field.isNested && "type-grid-nested"]} style={field.depth > 0 ? `padding-left: ${field.depth * 20 + 12}px` : undefined}>
                                          <span class="type-property font-mono text-[12px]">
                                            {field.depth > 0 && <span class="text-text-faint mr-1">↳</span>}
                                            {field.name}
                                          </span>
                                          <span class="font-mono text-[12px]" set:html={formatType(field)} />
                                        </div>
                                      ))}
                                    </div>
                                  )}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      )}

                      {/* No payload info */}
                      {!hasPayload && (
                        <p class="text-xs text-text-faint italic">No payload — lifecycle event</p>
                      )}
                    </div>
                  </section>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>

    <!-- Next Steps -->
    <section class="glass rounded-2xl p-6">
      <h3 class="font-semibold mb-3">Next Steps</h3>
      <div class="flex flex-col gap-2">
        <a href="/guides/voice/" class="text-sm text-accent hover:underline">→ Voice Streaming — stream audio into voice channels</a>
        <a href="/docs/IEvents/" class="text-sm text-accent hover:underline">→ IEvents API Reference — endpoint details and types</a>
        <a href="/docs/IMessages/" class="text-sm text-accent hover:underline">→ IMessages API Reference — send and query messages</a>
      </div>
    </section>
  </div>
</DocsLayout>
