---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { MousePointerClick, Palette, LayoutGrid, Zap, Code, ArrowRight } from 'lucide-astro';
---

<DocsLayout title="Interactive Controls — Argon Bot API" current="/guides/controls/" toc={[
  { id: "how-controls-work", title: "How Controls Work" },
  { id: "control-schema", title: "Control Schema" },
  { id: "oklch-colours", title: "OKLCH Colours" },
  { id: "colour-visualizer", title: "Colour Visualizer", depth: 1 },
  { id: "sending-controls", title: "Sending Controls" },
  { id: "handling-interactions", title: "Handling Interactions" },
  { id: "editing-controls", title: "Editing Controls" },
]}>
  <div class="animate-fade-in-up">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Interactive Controls</h1>
    <p class="text-text-secondary text-lg">
      Add buttons and other interactive components to messages.
      When a user clicks a control, your bot receives a <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">ControlInteraction</code> event.
    </p>
  </div>

  <div class="mt-10 space-y-12 animate-fade-in-up-delay-1">

    <!-- Overview -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <MousePointerClick class="size-5 text-accent" />
        <h2 id="how-controls-work" class="text-xl font-semibold">How Controls Work <a href="#how-controls-work" class="anchor-link">#</a></h2>
      </div>
      <div class="space-y-4">
        <p class="text-text-secondary">
          Controls are interactive UI elements attached to messages. They're sent as an optional <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">controls</code>
          array alongside the message text and entities. Controls are organized into <strong>rows</strong> — up to 5 rows with up to 5 controls each (25 total).
        </p>
        <div class="glass rounded-2xl p-5 border-l-2 border-accent">
          <p class="text-sm text-text-secondary">
            <strong>Two button variants:</strong>
            <span class="type-enum">Callback</span> buttons fire a <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">ControlInteraction</code> event with the button's <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">id</code>.
            <span class="type-enum">Link</span> buttons open a URL in the browser — no event is fired.
          </p>
        </div>
      </div>
    </section>

    <!-- Control shape -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <LayoutGrid class="size-5 text-accent" />
        <h2 id="control-schema" class="text-xl font-semibold">Control Schema <a href="#control-schema" class="anchor-link">#</a></h2>
      </div>

      <div class="glass rounded-2xl overflow-hidden">
        <div class="type-grid">
          <div class="type-grid-header">
            <span>Field</span>
            <span>Type</span>
            <span>Description</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">type</span>
            <span class="font-mono text-[12px]"><span class="type-enum">"button"</span></span>
            <span class="text-text-secondary text-[12px]">Control type. Currently only <code>button</code>.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">variant</span>
            <span class="font-mono text-[12px]"><span class="type-enum">"callback"</span> | <span class="type-enum">"link"</span></span>
            <span class="text-text-secondary text-[12px]">What happens on click.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">label</span>
            <span class="font-mono text-[12px]"><span class="type-keyword">string</span></span>
            <span class="text-text-secondary text-[12px]">Button text. Max 80 chars.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">id</span>
            <span class="font-mono text-[12px]"><span class="type-keyword">string?</span></span>
            <span class="text-text-secondary text-[12px]">Developer-defined ID. Required for callback, forbidden for link. Max 100 chars.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">url</span>
            <span class="font-mono text-[12px]"><span class="type-keyword">string?</span></span>
            <span class="text-text-secondary text-[12px]">URL for link buttons. Must be HTTPS. Required for link, forbidden for callback.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">colour</span>
            <span class="font-mono text-[12px]"><span class="type-name">OklchColor?</span></span>
            <span class="text-text-secondary text-[12px]">Accent colour in OKLCH colour space.</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">labelLocalizations</span>
            <span class="font-mono text-[12px]">Record&lt;<span class="type-keyword">string</span>, <span class="type-keyword">string</span>&gt;?</span>
            <span class="text-text-secondary text-[12px]">Localized labels keyed by BCP-47 tag (e.g. <code>"ru"</code>, <code>"en-US"</code>).</span>
          </div>
          <div class="type-grid-row">
            <span class="type-property font-mono text-[12px]">disabled</span>
            <span class="font-mono text-[12px]"><span class="type-keyword">boolean?</span></span>
            <span class="text-text-secondary text-[12px]">If true, button is visible but non-interactive.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- OKLCH Colors -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Palette class="size-5 text-accent" />
        <h2 id="oklch-colours" class="text-xl font-semibold">OKLCH Colours <a href="#oklch-colours" class="anchor-link">#</a></h2>
      </div>
      <div class="space-y-4">
        <p class="text-text-secondary">
          Buttons use <a href="https://oklch.com" class="text-accent hover:text-accent-hover">OKLCH</a> colours for theme-adaptive rendering.
          The client adjusts lightness to match the active theme while preserving hue and chroma.
        </p>
        <div class="glass rounded-2xl overflow-hidden">
          <div class="type-grid">
            <div class="type-grid-header">
              <span>Component</span>
              <span>Range</span>
              <span>Description</span>
            </div>
            <div class="type-grid-row">
              <span class="type-property font-mono text-[12px]">l</span>
              <span class="font-mono text-[12px]">0.40 — 0.80</span>
              <span class="text-text-secondary text-[12px]">Perceived lightness</span>
            </div>
            <div class="type-grid-row">
              <span class="type-property font-mono text-[12px]">c</span>
              <span class="font-mono text-[12px]">0.00 — 0.37</span>
              <span class="text-text-secondary text-[12px]">Chroma (saturation)</span>
            </div>
            <div class="type-grid-row">
              <span class="type-property font-mono text-[12px]">h</span>
              <span class="font-mono text-[12px]">0 — 360</span>
              <span class="text-text-secondary text-[12px]">Hue angle (degrees, exclusive 360)</span>
            </div>
          </div>
        </div>
        <div class="code-block text-[12px]">
          <pre set:html={`<span class="text-text-muted">// Common colours</span>
{ <span class="text-accent-2">"l"</span>: 0.72, <span class="text-accent-2">"c"</span>: 0.19, <span class="text-accent-2">"h"</span>: 142 }  <span class="text-text-muted">// green</span>
{ <span class="text-accent-2">"l"</span>: 0.55, <span class="text-accent-2">"c"</span>: 0.25, <span class="text-accent-2">"h"</span>: 29  }  <span class="text-text-muted">// red</span>
{ <span class="text-accent-2">"l"</span>: 0.65, <span class="text-accent-2">"c"</span>: 0.20, <span class="text-accent-2">"h"</span>: 260 }  <span class="text-text-muted">// blue</span>
{ <span class="text-accent-2">"l"</span>: 0.75, <span class="text-accent-2">"c"</span>: 0.18, <span class="text-accent-2">"h"</span>: 85  }  <span class="text-text-muted">// yellow</span>`} />
        </div>

        <!-- Interactive OKLCH Visualizer -->
        <div id="colour-visualizer">
          <h3 class="text-base font-semibold mb-3">Colour Visualizer</h3>
          <div class="glass rounded-2xl p-5 space-y-4">
            <!-- Preview -->
            <div class="flex items-center gap-4">
              <div id="oklch-preview" class="w-16 h-16 rounded-xl border border-oled-border transition-colors" style="background: oklch(0.65 0.20 260);"></div>
              <div class="flex-1 space-y-1">
                <div id="oklch-css" class="font-mono text-sm text-text-primary">oklch(0.65 0.20 260)</div>
                <div id="oklch-json" class="font-mono text-[12px] text-text-secondary" set:html={'{ "l": 0.65, "c": 0.20, "h": 260 }'}></div>
              </div>
              <button id="oklch-copy" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-accent/10 text-accent hover:bg-accent/20 transition-colors cursor-pointer" type="button">Copy JSON</button>
            </div>

            <!-- Sliders -->
            <div class="space-y-3">
              <div>
                <div class="flex justify-between items-center mb-1">
                  <label for="oklch-l" class="text-xs font-medium text-text-secondary">Lightness</label>
                  <span id="oklch-l-val" class="font-mono text-xs text-text-muted">0.65</span>
                </div>
                <input type="range" id="oklch-l" min="0.40" max="0.80" step="0.01" value="0.65"
                  class="oklch-slider w-full" style="--track-bg: linear-gradient(to right, oklch(0.40 0.20 260), oklch(0.80 0.20 260));" />
              </div>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <label for="oklch-c" class="text-xs font-medium text-text-secondary">Chroma</label>
                  <span id="oklch-c-val" class="font-mono text-xs text-text-muted">0.20</span>
                </div>
                <input type="range" id="oklch-c" min="0.00" max="0.37" step="0.01" value="0.20"
                  class="oklch-slider w-full" style="--track-bg: linear-gradient(to right, oklch(0.65 0.00 260), oklch(0.65 0.37 260));" />
              </div>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <label for="oklch-h" class="text-xs font-medium text-text-secondary">Hue</label>
                  <span id="oklch-h-val" class="font-mono text-xs text-text-muted">260</span>
                </div>
                <input type="range" id="oklch-h" min="0" max="359" step="1" value="260"
                  class="oklch-slider w-full" style="--track-bg: linear-gradient(to right, oklch(0.65 0.20 0), oklch(0.65 0.20 60), oklch(0.65 0.20 120), oklch(0.65 0.20 180), oklch(0.65 0.20 240), oklch(0.65 0.20 300), oklch(0.65 0.20 360));" />
              </div>
            </div>

            <!-- Presets -->
            <div class="flex flex-wrap gap-2 pt-1">
              <span class="text-xs text-text-muted self-center mr-1">Presets:</span>
              <button type="button" class="oklch-preset" data-l="0.72" data-c="0.19" data-h="142">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.72 0.19 142);"></span>Green
              </button>
              <button type="button" class="oklch-preset" data-l="0.55" data-c="0.25" data-h="29">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.55 0.25 29);"></span>Red
              </button>
              <button type="button" class="oklch-preset" data-l="0.65" data-c="0.20" data-h="260">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.65 0.20 260);"></span>Blue
              </button>
              <button type="button" class="oklch-preset" data-l="0.75" data-c="0.18" data-h="85">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.75 0.18 85);"></span>Yellow
              </button>
              <button type="button" class="oklch-preset" data-l="0.60" data-c="0.26" data-h="310">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.60 0.26 310);"></span>Pink
              </button>
              <button type="button" class="oklch-preset" data-l="0.70" data-c="0.15" data-h="200">
                <span class="inline-block w-3 h-3 rounded-full mr-1" style="background: oklch(0.70 0.15 200);"></span>Cyan
              </button>
            </div>

            <!-- Button preview -->
            <div class="pt-2 border-t border-oled-border-subtle">
              <span class="text-xs text-text-muted block mb-2">Button preview</span>
              <div class="flex gap-2">
                <button type="button" id="oklch-btn-preview"
                  class="px-4 py-2 rounded-lg text-sm font-medium text-white transition-colors cursor-default"
                  style="background: oklch(0.65 0.20 260);">
                  ✅ Deploy
                </button>
                <button type="button"
                  class="px-4 py-2 rounded-lg text-sm font-medium text-white/40 bg-white/5 cursor-default" disabled>
                  ❌ Cancel
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sending controls -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Code class="size-5 text-accent" />
        <h2 id="sending-controls" class="text-xl font-semibold">Sending Controls <a href="#sending-controls" class="anchor-link">#</a></h2>
      </div>
      <div class="space-y-4">
        <p class="text-text-secondary">
          Pass <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">controls</code> in your
          <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">IMessages/Send</code> or
          <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">IInteractions/Reply</code> request.
        </p>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">curl — send a message with buttons</h4>
          <pre set:html={`curl -X POST /IMessages/v1/Send \\
  -H "Authorization: Bot YOUR_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    <span class="text-accent-2">"channelId"</span>: <span class="text-accent-2">"..."</span>,
    <span class="text-accent-2">"text"</span>: <span class="text-accent-2">"Deploy to production?"</span>,
    <span class="text-accent-2">"randomId"</span>: 42,
    <span class="text-accent-2">"controls"</span>: [
      {
        <span class="text-accent-2">"controls"</span>: [
          {
            <span class="text-accent-2">"type"</span>: 0,
            <span class="text-accent-2">"variant"</span>: 0,
            <span class="text-accent-2">"label"</span>: <span class="text-accent-2">"✅ Deploy"</span>,
            <span class="text-accent-2">"id"</span>: <span class="text-accent-2">"deploy_confirm"</span>,
            <span class="text-accent-2">"colour"</span>: { <span class="text-accent-2">"l"</span>: 0.72, <span class="text-accent-2">"c"</span>: 0.19, <span class="text-accent-2">"h"</span>: 142 }
          },
          {
            <span class="text-accent-2">"type"</span>: 0,
            <span class="text-accent-2">"variant"</span>: 0,
            <span class="text-accent-2">"label"</span>: <span class="text-accent-2">"❌ Cancel"</span>,
            <span class="text-accent-2">"id"</span>: <span class="text-accent-2">"deploy_cancel"</span>,
            <span class="text-accent-2">"colour"</span>: { <span class="text-accent-2">"l"</span>: 0.55, <span class="text-accent-2">"c"</span>: 0.25, <span class="text-accent-2">"h"</span>: 29 }
          },
          {
            <span class="text-accent-2">"type"</span>: 0,
            <span class="text-accent-2">"variant"</span>: 1,
            <span class="text-accent-2">"label"</span>: <span class="text-accent-2">"📚 Runbook"</span>,
            <span class="text-accent-2">"url"</span>: <span class="text-accent-2">"https://wiki.example.com/deploy"</span>
          }
        ]
      }
    ]
  }'`} />
        </div>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">C# — MessageBuilder</h4>
          <pre set:html={`<span class="text-text-muted">// Fluent builder for messages with entities + controls</span>
var (text, entities, controls) = new MessageBuilder()
    .Text(<span class="text-accent-2">"Deploy to production?"</span>)
    .Row(row => row
        .CallbackButton(<span class="text-accent-2">"deploy_confirm"</span>, <span class="text-accent-2">"✅ Deploy"</span>,
            colour: new OklchColor(0.72f, 0.19f, 142))
        .CallbackButton(<span class="text-accent-2">"deploy_cancel"</span>, <span class="text-accent-2">"❌ Cancel"</span>,
            colour: new OklchColor(0.55f, 0.25f, 29))
        .LinkButton(<span class="text-accent-2">"📚 Runbook"</span>, <span class="text-accent-2">"https://wiki.example.com/deploy"</span>))
    .Build();

await channel.SendMessage(text, entities, randomId, replyTo: null, controls);`} />
        </div>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">C# — Rich text with entities + controls</h4>
          <pre set:html={`var (text, entities, controls) = new MessageBuilder()
    .Bold(<span class="text-accent-2">"Build #847"</span>)
    .Text(<span class="text-accent-2">" passed on "</span>)
    .Italic(<span class="text-accent-2">"main"</span>)
    .Text(<span class="text-accent-2">" — "</span>)
    .Url(<span class="text-accent-2">"ci.example.com"</span>, <span class="text-accent-2">"/builds/847"</span>)
    .Row(row => row
        .CallbackButton(<span class="text-accent-2">"deploy"</span>, <span class="text-accent-2">"Deploy"</span>,
            colour: new OklchColor(0.72f, 0.19f, 142))
        .CallbackButton(<span class="text-accent-2">"logs"</span>, <span class="text-accent-2">"View Logs"</span>))
    .Build();`} />
        </div>
      </div>
    </section>

    <!-- ControlInteraction event -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <Zap class="size-5 text-accent" />
        <h2 id="handling-interactions" class="text-xl font-semibold">Handling Interactions <a href="#handling-interactions" class="anchor-link">#</a></h2>
      </div>
      <div class="space-y-4">
        <p class="text-text-secondary">
          When a user clicks a <span class="type-enum">Callback</span> button, your SSE stream receives a <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">ControlInteraction</code> event.
          Subscribe to the <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">ControlInteractions</code> intent (bit 13, value 8192).
        </p>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">Event payload</h4>
          <pre set:html={`event: ControlInteraction
data: {
  <span class="text-accent-2">"interactionId"</span>: <span class="text-accent-2">"a1b2c3d4-..."</span>,
  <span class="text-accent-2">"controlType"</span>: 0,
  <span class="text-accent-2">"messageId"</span>: 123456789,
  <span class="text-accent-2">"channelId"</span>: <span class="text-accent-2">"..."</span>,
  <span class="text-accent-2">"spaceId"</span>: <span class="text-accent-2">"..."</span>,
  <span class="text-accent-2">"user"</span>: {
    <span class="text-accent-2">"userId"</span>: <span class="text-accent-2">"..."</span>,
    <span class="text-accent-2">"username"</span>: <span class="text-accent-2">"alice"</span>,
    <span class="text-accent-2">"displayName"</span>: <span class="text-accent-2">"Alice"</span>,
    <span class="text-accent-2">"avatarUrl"</span>: null
  },
  <span class="text-accent-2">"controlId"</span>: <span class="text-accent-2">"deploy_confirm"</span>
}`} />
        </div>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">Responding — reply with updated controls</h4>
          <pre set:html={`<span class="text-text-muted">// Handle the interaction in your SSE event loop</span>
if (eventType == <span class="text-accent-2">"ControlInteraction"</span>) {
    var data = JsonSerializer.Deserialize&lt;ControlInteractionEvent&gt;(payload);

    if (data.ControlId == <span class="text-accent-2">"deploy_confirm"</span>) {
        <span class="text-text-muted">// Reply to the channel</span>
        await httpClient.PostAsJsonAsync(<span class="text-accent-2">"/IInteractions/v1/Reply"</span>, new {
            channelId = data.ChannelId,
            text      = <span class="text-accent-2">"🚀 Deploying..."</span>,
            randomId  = Random.Shared.NextInt64()
        });

        <span class="text-text-muted">// Disable the buttons on the original message</span>
        await httpClient.PatchAsJsonAsync(<span class="text-accent-2">"/IInteractions/v1/EditMessage"</span>, new {
            channelId = data.ChannelId,
            messageId = data.MessageId,
            controls  = new[] {
                new { controls = new[] {
                    new { type = 0, variant = 0, label = <span class="text-accent-2">"✅ Deployed"</span>, id = <span class="text-accent-2">"deploy_confirm"</span>, disabled = true },
                    new { type = 0, variant = 0, label = <span class="text-accent-2">"❌ Cancel"</span>, id = <span class="text-accent-2">"deploy_cancel"</span>, disabled = true }
                }}
            }
        });
    }
}`} />
        </div>

        <div class="code-block text-[12px]">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">TypeScript — full interaction handler</h4>
          <pre set:html={`const sse = new EventSource(
  ` + '`' + `/IEvents/v1/Stream?intents=` + '${' + `8192}` + '`' + `,
  { headers: { Authorization: ` + '`' + `Bot ` + '${' + `TOKEN}` + '`' + ` } }
);

sse.addEventListener(<span class="text-accent-2">"ControlInteraction"</span>, async (e) =&gt; {
  const { controlId, channelId, messageId, user } = JSON.parse(e.data);

  switch (controlId) {
    case <span class="text-accent-2">"approve"</span>:
      await fetch(<span class="text-accent-2">"/IInteractions/v1/Reply"</span>, {
        method: <span class="text-accent-2">"POST"</span>,
        headers: { Authorization: ` + '`' + `Bot ` + '${' + `TOKEN}` + '`' + `, "Content-Type": "application/json" },
        body: JSON.stringify({
          channelId,
          text: ` + '`' + `Approved by ` + '${' + `user.displayName}` + '`' + `,
          randomId: Date.now(),
        }),
      });
      break;
  }
});`} />
        </div>
      </div>
    </section>

    <!-- Editing controls -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <ArrowRight class="size-5 text-accent" />
        <h2 id="editing-controls" class="text-xl font-semibold">Editing Controls <a href="#editing-controls" class="anchor-link">#</a></h2>
      </div>
      <div class="space-y-4">
        <p class="text-text-secondary">
          Use <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">PATCH /IInteractions/v1/EditMessage</code> to update the text or controls on a message your bot sent.
          Pass an empty <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">controls: []</code> array to remove all controls.
        </p>

        <div class="glass rounded-2xl p-5 border-l-2 border-accent">
          <h4 class="text-sm font-semibold mb-2">Limits</h4>
          <ul class="text-sm text-text-secondary space-y-1">
            <li>Max <strong>5 rows</strong> per message, <strong>5 controls</strong> per row (25 total)</li>
            <li>Control <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">id</code> values must be unique across all rows</li>
            <li>Link button URLs must be <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">https://</code> or <code class="bg-oled-elevated px-1 py-0.5 rounded font-mono text-[11px]">http://</code></li>
            <li>Bots can only edit their own messages</li>
            <li>Rate limit: <strong>15 requests/min</strong> for IInteractions</li>
          </ul>
        </div>
      </div>
    </section>

  </div>
</DocsLayout>

<style>
  .oklch-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 3px;
    background: var(--track-bg, #333);
    outline: none;
  }
  .oklch-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid rgba(255,255,255,0.3);
    box-shadow: 0 0 4px rgba(0,0,0,0.5);
    cursor: pointer;
  }
  .oklch-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid rgba(255,255,255,0.3);
    box-shadow: 0 0 4px rgba(0,0,0,0.5);
    cursor: pointer;
  }
  .oklch-preset {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-oled-elevated);
    border: 1px solid var(--color-oled-border-subtle);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .oklch-preset:hover {
    background: var(--color-oled-hover);
    border-color: var(--color-oled-border);
  }
</style>

<script>
  function initOklchVisualizer() {
    const lSlider = document.getElementById('oklch-l') as HTMLInputElement | null;
    const cSlider = document.getElementById('oklch-c') as HTMLInputElement | null;
    const hSlider = document.getElementById('oklch-h') as HTMLInputElement | null;
    if (!lSlider || !cSlider || !hSlider) return;

    const lVal = document.getElementById('oklch-l-val')!;
    const cVal = document.getElementById('oklch-c-val')!;
    const hVal = document.getElementById('oklch-h-val')!;
    const preview = document.getElementById('oklch-preview')!;
    const cssOut = document.getElementById('oklch-css')!;
    const jsonOut = document.getElementById('oklch-json')!;
    const btnPreview = document.getElementById('oklch-btn-preview')!;
    const copyBtn = document.getElementById('oklch-copy')!;

    function update() {
      const l = parseFloat(lSlider!.value);
      const c = parseFloat(cSlider!.value);
      const h = parseInt(hSlider!.value);

      const css = `oklch(${l.toFixed(2)} ${c.toFixed(2)} ${h})`;
      const json = `{ "l": ${l.toFixed(2)}, "c": ${c.toFixed(2)}, "h": ${h} }`;

      preview.style.background = css;
      btnPreview.style.background = css;
      cssOut.textContent = css;
      jsonOut.textContent = json;
      lVal.textContent = l.toFixed(2);
      cVal.textContent = c.toFixed(2);
      hVal.textContent = String(h);

      // Update slider track gradients
      lSlider!.style.setProperty('--track-bg',
        `linear-gradient(to right, oklch(0.40 ${c.toFixed(2)} ${h}), oklch(0.80 ${c.toFixed(2)} ${h}))`);
      cSlider!.style.setProperty('--track-bg',
        `linear-gradient(to right, oklch(${l.toFixed(2)} 0.00 ${h}), oklch(${l.toFixed(2)} 0.37 ${h}))`);
      hSlider!.style.setProperty('--track-bg',
        `linear-gradient(to right, oklch(${l.toFixed(2)} ${c.toFixed(2)} 0), oklch(${l.toFixed(2)} ${c.toFixed(2)} 60), oklch(${l.toFixed(2)} ${c.toFixed(2)} 120), oklch(${l.toFixed(2)} ${c.toFixed(2)} 180), oklch(${l.toFixed(2)} ${c.toFixed(2)} 240), oklch(${l.toFixed(2)} ${c.toFixed(2)} 300), oklch(${l.toFixed(2)} ${c.toFixed(2)} 360))`);
    }

    lSlider.addEventListener('input', update);
    cSlider.addEventListener('input', update);
    hSlider.addEventListener('input', update);

    copyBtn.addEventListener('click', () => {
      const l = parseFloat(lSlider!.value);
      const c = parseFloat(cSlider!.value);
      const h = parseInt(hSlider!.value);
      const json = `{ "l": ${l.toFixed(2)}, "c": ${c.toFixed(2)}, "h": ${h} }`;
      navigator.clipboard.writeText(json).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy JSON'; }, 1500);
      });
    });

    document.querySelectorAll('.oklch-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        lSlider!.value = el.dataset.l!;
        cSlider!.value = el.dataset.c!;
        hSlider!.value = el.dataset.h!;
        update();
      });
    });

    update();
  }

  document.addEventListener('astro:page-load', initOklchVisualizer);
  initOklchVisualizer();
</script>
