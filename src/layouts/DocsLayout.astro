---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import fullManifest from '../data/api-manifest.json';
const manifest = fullManifest.interfaces;

interface TocEntry {
  id: string;
  title: string;
  depth?: number;
}

interface Props {
  title?: string;
  current?: string;
  toc?: TocEntry[];
}

const { title = 'Docs — Argon Bot API', current = '/docs/', toc = [] } = Astro.props;

const stableInterfaces = manifest.filter((i: any) => i.isStable && !i.isDeprecated);
const draftInterfaces = manifest.filter((i: any) => !i.isStable && !i.isDeprecated);
const deprecatedInterfaces = manifest.filter((i: any) => i.isDeprecated);

// Page ordering for prev/next navigation
const pageOrder = [
  { href: '/guides/what-are-bots/', label: 'What Are Bots?' },
  { href: '/guides/getting-started/', label: 'Getting Started' },
  { href: '/guides/events/', label: 'Real-time Events (SSE)' },
  { href: '/guides/voice/', label: 'Voice Streaming' },
  { href: '/guides/message-entities/', label: 'Message Entities' },
  { href: '/guides/controls/', label: 'Interactive Controls' },
  { href: '/guides/reactions/', label: 'Reactions' },
  { href: '/guides/message-constructor/', label: 'Message Constructor' },
  { href: '/guides/permissions/', label: 'Permissions & Intents' },
  { href: '/guides/rate-limits/', label: 'Rate Limits' },
  { href: '/guides/error-handling/', label: 'Error Handling' },
  { href: '/guides/glossary/', label: 'Glossary' },
  { href: '/docs/', label: 'API Overview' },
  ...stableInterfaces.map((i: any) => ({ href: `/docs/${i.name}/`, label: i.name })),
  ...draftInterfaces.map((i: any) => ({ href: `/docs/${i.name}/`, label: i.name })),
];
const currentIdx = pageOrder.findIndex(p => p.href === current);
const prevPage = currentIdx > 0 ? pageOrder[currentIdx - 1] : null;
const nextPage = currentIdx >= 0 && currentIdx < pageOrder.length - 1 ? pageOrder[currentIdx + 1] : null;

function formatVersion(v: number): string {
  if (v > 1000) {
    const s = v.toString();
    return `${s.slice(0, 4)}-${s.slice(4, 6)}-${s.slice(6, 8)}`;
  }
  return `v${v}`;
}
---

<Layout title={title}>
  <Navbar current="/docs/" />
  <div class="flex pt-14 min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden lg:flex w-64 flex-col fixed top-14 bottom-0 border-r border-oled-border-subtle bg-oled-bg/50 overflow-y-auto">
      <nav class="flex flex-col gap-1 p-4">
        <div class="mb-1">
          <span class="section-label px-3">Guides</span>
        </div>
        <a
          href="/guides/what-are-bots/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/what-are-bots/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          What Are Bots?
        </a>
        <a
          href="/guides/getting-started/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/getting-started/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Getting Started
        </a>
        <a
          href="/guides/events/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/events/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Real-time Events (SSE)
        </a>
        <a
          href="/guides/voice/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/voice/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Voice Streaming
        </a>
        <a
          href="/guides/message-entities/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/message-entities/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Message Entities
        </a>
        <a
          href="/guides/controls/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/controls/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Interactive Controls
        </a>
        <a
          href="/guides/reactions/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/reactions/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Reactions
        </a>
        <a
          href="/guides/message-constructor/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/message-constructor/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Message Constructor
        </a>
        <a
          href="/guides/permissions/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/permissions/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Permissions & Intents
        </a>
        <a
          href="/guides/rate-limits/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/rate-limits/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Rate Limits
        </a>
        <a
          href="/guides/error-handling/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/error-handling/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Error Handling
        </a>
        <a
          href="/guides/glossary/"
          class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors",
            current === '/guides/glossary/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Glossary
        </a>

        <div class="mt-4 mb-1">
          <span class="section-label px-3">API Reference</span>
        </div>
        <a
          href="/docs/"
          class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors",
            current === '/docs/' ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
        >
          Overview
        </a>

        {stableInterfaces.length > 0 && (
          <div class="mt-4 mb-1">
            <span class="section-label px-3">Stable</span>
          </div>
        )}
        {stableInterfaces.map((iface: any) => (
          <a
            href={`/docs/${iface.name}/`}
            class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors flex items-center justify-between",
              current === `/docs/${iface.name}/` ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
          >
            <span>{iface.name}</span>
            <span class="text-[10px] text-text-muted font-mono">{formatVersion(iface.version)}</span>
          </a>
        ))}

        {draftInterfaces.length > 0 && (
          <div class="mt-4 mb-1">
            <span class="section-label px-3">Draft</span>
          </div>
        )}
        {draftInterfaces.map((iface: any) => (
          <a
            href={`/docs/${iface.name}/`}
            class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors flex items-center justify-between",
              current === `/docs/${iface.name}/` ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
          >
            <span>{iface.name}</span>
            <span class="text-[10px] text-status-degraded font-mono">draft</span>
          </a>
        ))}

        {deprecatedInterfaces.length > 0 && (
          <div class="mt-4 mb-1">
            <span class="section-label px-3">Deprecated</span>
          </div>
        )}
        {deprecatedInterfaces.map((iface: any) => (
          <a
            href={`/docs/${iface.name}/`}
            class:list={["px-3 py-1.5 rounded-lg text-sm transition-colors line-through opacity-60",
              current === `/docs/${iface.name}/` ? 'text-accent bg-accent-subtle' : 'text-text-secondary hover:text-text-primary hover:bg-oled-hover']}
          >
            {iface.name}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Main content -->
    <main id="main-content" class="flex-1 lg:ml-64 2xl:mr-56 pb-16 min-w-0 overflow-x-hidden">
      <article class="max-w-4xl mx-auto px-4 sm:px-6 py-6 sm:py-10 min-w-0">
        <slot />

        <!-- Prev / Next navigation -->
        {(prevPage || nextPage) && (
          <nav class="mt-16 pt-8 border-t border-oled-border-subtle flex items-stretch justify-between gap-4">
            {prevPage ? (
              <a href={prevPage.href} class="group flex-1 flex flex-col items-start gap-1 px-4 py-3 rounded-xl border border-oled-border-subtle hover:border-accent/30 hover:bg-oled-hover/50 transition-all">
                <span class="text-[11px] text-text-muted uppercase tracking-wider">Previous</span>
                <span class="text-sm font-medium text-text-secondary group-hover:text-accent transition-colors">← {prevPage.label}</span>
              </a>
            ) : <div class="flex-1" />}
            {nextPage ? (
              <a href={nextPage.href} class="group flex-1 flex flex-col items-end gap-1 px-4 py-3 rounded-xl border border-oled-border-subtle hover:border-accent/30 hover:bg-oled-hover/50 transition-all text-right">
                <span class="text-[11px] text-text-muted uppercase tracking-wider">Next</span>
                <span class="text-sm font-medium text-text-secondary group-hover:text-accent transition-colors">{nextPage.label} →</span>
              </a>
            ) : <div class="flex-1" />}
          </nav>
        )}
      </article>
    </main>

    {toc.length > 0 && (
      <aside class="hidden 2xl:flex w-56 flex-col fixed top-14 right-0 bottom-0 overflow-y-auto py-8 px-4">
        <div class="text-[11px] font-semibold uppercase tracking-wider text-text-muted mb-3">On this page</div>
        <nav class="flex flex-col gap-0.5 border-l border-oled-border-subtle">
          {toc.map((entry) => (
            <a
              href={`#${entry.id}`}
              class="toc-link text-[13px] leading-snug py-1 pl-3 -ml-px border-l border-transparent text-text-muted hover:text-text-primary hover:border-accent/40 transition-colors"
              data-toc-id={entry.id}
              style={entry.depth && entry.depth > 0 ? `padding-left: ${0.75 + entry.depth * 0.75}rem` : undefined}
            >
              {entry.title}
            </a>
          ))}
        </nav>
      </aside>
    )}
  </div>
  <div class="lg:ml-64">
    <Footer />
  </div>
</Layout>

<script>
  function initScrollSpy() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (!links.length) return;

    const ids = Array.from(links).map(l => l.dataset.tocId!);
    const sections = ids.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    if (!sections.length) return;

    const OFFSET = 80;
    let active = '';

    function update() {
      let current = ids[0];
      for (let i = 0; i < sections.length; i++) {
        if (sections[i].getBoundingClientRect().top <= OFFSET) {
          current = ids[i];
        }
      }
      if (current !== active) {
        active = current;
        links.forEach(l => {
          const isActive = l.dataset.tocId === active;
          l.classList.toggle('text-accent', isActive);
          l.classList.toggle('!border-accent', isActive);
          l.classList.toggle('text-text-muted', !isActive);
        });
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }
  document.addEventListener('astro:page-load', initScrollSpy);
  initScrollSpy();
</script>

<script>
  function initReadingTime() {
    const article = document.querySelector('article');
    if (!article) return;
    if (article.querySelector('.reading-time')) return;

    const text = article.textContent || '';
    const words = text.trim().split(/\s+/).filter(w => w.length > 0).length;
    const minutes = Math.max(1, Math.round(words / 220));

    const h1 = article.querySelector('h1');
    if (!h1) return;

    // Find the subtitle paragraph right after h1
    const subtitle = h1.nextElementSibling;
    const target = subtitle && subtitle.tagName === 'P' ? subtitle : h1;

    const el = document.createElement('div');
    el.className = 'reading-time flex items-center gap-2 mt-3 text-[13px] text-text-muted';
    el.innerHTML = `<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${minutes} min read`;

    target.insertAdjacentElement('afterend', el);
  }

  document.addEventListener('astro:page-load', initReadingTime);
  initReadingTime();
</script>
